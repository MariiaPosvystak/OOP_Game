<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OOP_Game.ViewModels"
             x:Class="OOP_Game.MainPage">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="20"
          BackgroundColor="{Binding SelectedTheme.BackgroundColor}">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="5">

            <Label Text="🧩 Пятнашки"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{Binding SelectedTheme.TextColor}"
                   FontFamily="{Binding SelectedTheme.FontFamily}" />

            <Label Text="{Binding Player.Name}"
                   TextColor="{Binding SelectedTheme.TextColor}" />

            <Label Text="{Binding Moves, StringFormat='Ходы: {0}'}"
                   TextColor="{Binding SelectedTheme.TextColor}" />

            <Label Text="{Binding TimeText, StringFormat='Время: {0}'}"
                   TextColor="{Binding SelectedTheme.TextColor}" />

            <!-- THEME PICKER -->
            <Picker Title="Тема"
                    ItemsSource="{Binding Themes}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedTheme}" />

            <!-- BUTTON -->
            <Button Text="Новая игра"
                    Command="{Binding StartNewGameCommand}" />
        </VerticalStackLayout>

        <!-- GAME GRID -->
        <Grid Grid.Row="2"
              RowDefinitions="*,*,*,*"
              ColumnDefinitions="*,*,*,*"
              Margin="0,20,0,0">

            <CollectionView ItemsSource="{Binding Tiles}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="4"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0"
                               Margin="3"
                               CornerRadius="12"
                               HasShadow="True"
                               BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=SelectedTheme.TileColor}">

                            <Frame.Triggers>
                                <Trigger TargetType="Frame" Property="IsVisible" Value="True">
                                    <Trigger.EnterActions>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Frame.Triggers>

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=TileTappedCommand}"
                                        CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>

                            <Label Text="{Binding Value}"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    TextColor="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=SelectedTheme.TextColor}" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>
